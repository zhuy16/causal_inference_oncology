    affiliation: "GitHub"
repository-code: "https://github.com/zhuy16/causal_inference_multiomics"
license: MIT
version: "1.0.0"
date-released: "2026-04-30"
keywords:
  - causal inference
  - survival analysis
  - propensity score matching
  - inverse probability weighting
  - mediation analysis
  - instrumental variables
  - difference-in-differences
  - TCGA
  - oncology
  - reproducible research
